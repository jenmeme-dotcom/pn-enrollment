PORT=4321
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_FILE=./data/bmhi.sqlite
UPLOAD_DIR=./data/uploads
GHL_WEBHOOK_SECRET=replace-with-ghl-shared-secret
INSTITUTE_NAME=Broward-Miami Health Institute
INSTITUTE_WEBSITE=https://www.browardmiamihi.com
PUBLIC_APP_URL=https://bmhi-student-portal.onrender.com

# External student email delivery
# Set EMAIL_DELIVERY_ENABLED=true only after SMTP credentials are added.
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=messages@your-school-domain.com
SMTP_PASS=replace-with-smtp-password-or-api-key
SMTP_FROM="Broward-Miami Health Institute <messages@your-school-domain.com>"

# Canvas publishing
CANVAS_BASE_URL=https://your-school.instructure.com
CANVAS_ACCESS_TOKEN=replace-with-canvas-access-token
CANVAS_ACCOUNT_ID=1
# CANVAS_COURSE_ID=12345
# CANVAS_SIS_COURSE_ID=BMHI-introduction-to-nursing-practical-nursing
# CANVAS_PUBLISH=false
